ALIST_BASE_URL=http://openlist:5244
ALIST_USERNAME=admin
ALIST_PASSWORD=replace-with-openlist-password
ALLOWED_ROOT_PATHS=/Movies,/Shows
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=turn:sync-seat.example.com:3478?transport=udp,turn:sync-seat.example.com:3478?transport=tcp
WEBRTC_TURN_USERNAME=sync-seat
TURN_AUTH_SECRET=replace-with-random-turn-auth-secret
TURN_CREDENTIAL_TTL_SECONDS=3600
SERVER_PORT=3000
WEB_ORIGIN=https://sync-seat.example.com:5173
LOG_LEVEL=info
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=14d
LOG_MAX_FILE_SIZE=20m

# Docker Compose / HTTPS 部署示例，真实密钥只写入服务器本机 .env。
SYNC_SEAT_IMAGE=ghcr.io/your-github-user/sync-seat:latest
NGINX_IMAGE=docker.1ms.run/nginx:alpine
ACME_IMAGE=docker.1panel.live/neilpang/acme.sh:latest
COTURN_IMAGE=docker.1panel.live/coturn/coturn:latest
TARGET_DOMAIN=sync-seat.example.com
NGINX_HTTP_HOST_PORT=80
NGINX_HTTPS_HOST_PORT=5173
# 必须改成服务器真实公网 IP；语音强制 TURN，中继端口不可达会导致无法通话。
TURN_EXTERNAL_IP=203.0.113.10
TURN_PORT=3478
TURN_REALM=sync-seat.example.com

# 内置 OpenList。Sync Seat 容器内默认通过 http://openlist:5244 访问。
OPENLIST_IMAGE=docker.1ms.run/openlistteam/openlist:beta-aio
OPENLIST_HOST_PORT=5244
OPENLIST_PUID=0
OPENLIST_PGID=0
TZ=Asia/Shanghai

# 阿里云 DNS 示例；真实 AccessKey 只写入本机 .env。
Ali_Key=your-ali-key
Ali_Secret=your-ali-secret
