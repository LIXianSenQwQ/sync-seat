ALIST_BASE_URL=https://alist.example.com
ALIST_USERNAME=admin
ALIST_PASSWORD=replace-with-alist-password
ALLOWED_ROOT_PATHS=/Movies,/Shows
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=
SERVER_PORT=3000
WEB_ORIGIN=http://localhost:5173

# Docker Compose / HTTPS 部署示例，真实 DNS 密钥只写入本机 .env。
SYNC_SEAT_IMAGE=ghcr.io/your-github-user/sync-seat:latest
TARGET_DOMAIN=sync-seat.example.com
# 阿里云 DNS 示例；真实 AccessKey 只写入本机 .env。
Ali_Key=your-ali-key
Ali_Secret=your-ali-secret
